policies {
  key: "publisher-1@testpublisher.com/workload-1"
  value {
    publisher_id: "publisher-1@testpublisher.com"
    workload_id: "workload-1"
    # trust_domain is ignored by PolicyMapper
    operator: "example.org/test_operator_role"
    certificate_attributes {
      max_certificate_validity {
        seconds: 3600
      }
      x509_extensions {
        basic_constraints {
          ca_certificate {
            path_len_constraint: 1
          }
        }
        name_constraints {
          permitted_subtree: ".example1.org"
          permitted_subtree: ".example2.org"
        }
      }
      certificate_subject {
        attributes {
          key: "2.5.4.3"
          value: "test"
        }
      }
    }
    reference_values {
      oak_reference_values {
        oak_containers: {
          root_layer: {
            insecure: { }
          }
