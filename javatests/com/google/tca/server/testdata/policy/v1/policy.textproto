# proto-file: api/google/tca/policy/v1/tca_policy.proto
# proto-message: google.tca.policy.v1.Policies
#
issuer: "https://accounts.google.com"
subject: "jwt-token-test-sub"
policies {
  key: "{publisher_id_to_replace}/{workload_id_to_replace}"
  value {
    publisher_id: "{publisher_id_to_replace}"
    workload_id: "{workload_id_to_replace}"
    # trust_domain is ignored by PolicyMapper
    operator: "example.org/test_operator_role"
    certificate_attributes {
      max_certificate_validity {
        seconds: 3600
      }
      x509_extensions {
        basic_constraints {
          ca_certificate {
            path_len_constraint: 1
          }
        }
        name_constraints {
          permitted_subtree: ".example1.org"
          permitted_subtree: ".example2.org"
        }
      }
      certificate_subject {
        attributes {
          key: "2.5.4.3"
          value: "test"
        }
      }
    }
    reference_values {
      oak_reference_values {
        {oak_containers_reference_values}
      }
    }
  }
}
