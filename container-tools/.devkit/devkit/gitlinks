set -o errexit
set -o nounset
set -o pipefail

function usage() {
  declare -r -i exitval=${1-1}
  cat <<USAGE
usage: $(basename "${BASH_SOURCE[0]}") [-h] {--check|--install|--update}

Manage gitlinks and submodules within the project.

options:
  -h, --help            Show this help message and exit.
  --check               Validate that submodules are in sync with gitlinks (disk
                        matches index) and that gitlinks match their specified
                        remote branches in .gitmodules. This is typically used
                        as a pre-commit hook.
  --install             Add the 'gitlinks' pre-commit hook to
                        .pre-commit-config.yaml. The hook will run
                        'devkit/gitlinks --check' automatically.
  --update              Update all submodules to match their latest remote
                        branches as specified in .gitmodules, and stage the
                        changes in the parent repository.
USAGE
  exit "${exitval}"
}

function check() {
  # 1. Get all submodule paths from .gitmodules
  submodule_configs=$(git config --file .gitmodules --get-regexp "submodule\..*\.path" || true)

  if [[ -z "$submodule_configs" ]]; then
    echo "No submodules found in .gitmodules."
    return 0
  fi

  mismatch_found=0

    while read -r key path; do
      [[ -z "$key" ]] && continue

      # Extract submodule name
      name="${key#submodule.}"
      name="${name%.path}"

      branch=$(git config --file .gitmodules --get "submodule.$name.branch" || echo "main")
      url=$(git config --file .gitmodules --get "submodule.$name.url" || true)

      current_sha=$(git rev-parse ":$path" 2>/dev/null || true)
      target_sha=$(git ls-remote "$url" "$branch" | awk '{print $1}' || true)

      if [[ -z "$current_sha" ]]; then
        echo "Error: Submodule '$name' path '$path' not found in parent index." >&2
        mismatch_found=1
        continue
      fi

      if [[ -z "$target_sha" ]]; then
        echo "Error: Could not reach remote for '$name' ($url)." >&2
        mismatch_found=1
        continue
      fi

      if [[ "$current_sha" != "$target_sha" ]]; then
        echo "Mismatch in '$path':" >&2
        echo "   Index Gitlink: $current_sha" >&2
        echo "   Remote ($branch): $target_sha" >&2
        mismatch_found=1
      else
        echo "'$path' matches remote."
      fi
    done <<< "$submodule_configs"

    if [[ "$mismatch_found" -ne 0 ]]; then
      exit 1
    fi
}

function install() {
  local config_file=".pre-commit-config.yaml"

  if [[ ! -f "${config_file}" ]]; then
    echo "Error: ${config_file} not found in current directory." >&2
    echo "Please run this script from the root of your project." >&2
    exit 1
  fi

  if grep -q "id: gitlinks" "${config_file}"; then
    echo "The gitlinks hook is already present in ${config_file}."
    return 0
  fi

  local hook_block="      - id: gitlinks
        name: Check gitlinks
        language: script
        entry: devkit/gitlinks --check
        always_run: true
        pass_filenames: false"

  # Check if 'repo: local' section exists
  if grep -q "repo: local" "${config_file}"; then
    echo "Found 'repo: local' section. Adding hook..."

    # Insert under 'repo: local' -> 'hooks:'
    awk -v hook_block="${hook_block}" '
      /repo: local/ { in_local = 1 }
      in_local && /hooks:/ {
        print $0;
        print hook_block;
        in_local = 0;
        next;
      }
      { print }
    ' "${config_file}" > "${config_file}.tmp"

    mv "${config_file}.tmp" "${config_file}"
    echo "Successfully added gitlinks hook to 'repo: local' section."
  else
    echo "'repo: local' section not found. Appending to the end of ${config_file}..."
    cat <<EOF >> "${config_file}"

  - repo: local
    hooks:
${hook_block}
EOF
    echo "Successfully appended 'repo: local' section with gitlinks hook."
  fi
}

function update() {
  echo "Updating all submodules to match their remote branches..."
  git submodule update --remote --recursive

  # Stage the updated gitlinks so they are in sync with the index
  submodule_paths=$(git config --file .gitmodules --get-regexp "submodule\..*\.path" | awk '{print $2}' || true)
  if [[ -n "$submodule_paths" ]]; then
    while read -r path; do
      if [[ -n "$path" ]]; then
        git add "$path"
      fi
    done <<< "$submodule_paths"
  fi

  echo "Submodules updated and staged."
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h | --help)
      usage 0
      ;;
    --check)
      check
      exit 0
      ;;
    --install)
      install
      exit 0
      ;;
    --update)
      update
      exit 0
      ;;
    *)
      usage
      ;;
  esac
done

usage
