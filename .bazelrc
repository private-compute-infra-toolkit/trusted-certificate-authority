try-import %workspace%/google-internal/.bazelrc

# Enforce a consistent Java version for all Bazel commands.
build --java_language_version=17
build --java_runtime_version=remotejdk_17
test --java_language_version=17
test --java_runtime_version=remotejdk_17
run --java_language_version=17
run --java_runtime_version=remotejdk_17

# Enable experimental cc_static_library rule
build --experimental_cc_static_library
test --experimental_cc_static_library
run --experimental_cc_static_library


build --incompatible_strict_action_env
build --strip=always
build:run_all_tests --cache_test_results=no

common --repo_env=BAZEL_DO_NOT_DETECT_CPP_TOOLCHAIN=1

# Use nightly rustc by default
build --@rules_rust//rust/toolchain/channel=nightly

# Output more information on test failures
common --verbose_failures
test --test_output=errors
test --test_verbose_timeout_warnings
build --incompatible_disallow_empty_glob=false
